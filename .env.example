# Point these at your own hosted JSON feeds to go fully live.
# When unset, the app uses the bundled sample data in src/data/.

# Tab 1 — Main Tools (your curated toolkit API)
# VITE_MAIN_TOOLS_URL=https://your-api.example.com/mainTools.json

# Tab 2 — Community Tools (auto-updating external feed)
# VITE_COMMUNITY_TOOLS_URL=https://raw.githubusercontent.com/your-org/RobloxXea-CommunityFeed/main/communityTools.json
